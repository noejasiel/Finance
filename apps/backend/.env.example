NODE_ENV=development
PORT=3001

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxx

# Session
SESSION_SECRET=change-me-to-at-least-32-chars-long-random-string

# Internal API (GitHub Actions scheduler)
INTERNAL_API_TOKEN=change-me-to-a-random-token

# Frontend URL (for CORS)
APP_URL=http://localhost:3000

# WhatsApp auth strategy: "local" for dev, "remote" for production
WA_AUTH_STRATEGY=local
