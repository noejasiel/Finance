NODE_ENV=production
PORT=3001

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-xxxx

# Session secret (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-to-at-least-32-chars-long-random-string

# Internal API token (generate: openssl rand -hex 32)
INTERNAL_API_TOKEN=change-me-to-a-random-token

# Frontend URL (your domain or VPS IP)
APP_URL=https://tudominio.com

# WhatsApp
WA_AUTH_STRATEGY=local
WA_ALLOWED_IDS=
